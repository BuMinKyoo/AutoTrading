<Window
    x:Class="AutoGetMoney.View.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AutoGetMoney_Behavior="clr-namespace:AutoGetMoney.CommandBehavior"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:AutoGetMoney"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="1000"
    Height="620"
    Style="{StaticResource DefaultStyle}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="100*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="20*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Grid.Column="1"
            Orientation="Horizontal">
            <ComboBox
                Height="30"
                Margin="5"
                VerticalAlignment="Top"
                VerticalContentAlignment="Center"
                ItemsSource="{Binding ObcTradeModeList}"
                SelectedItem="{Binding UiStrTradeMode, Mode=TwoWay}" />
            <TextBox
                Width="300"
                Height="30"
                Margin="5"
                VerticalAlignment="Top"
                VerticalContentAlignment="Center"
                Text="{Binding UiStrCommunicationUrl}" />
        </StackPanel>

        <WrapPanel
            Grid.Row="1"
            Grid.Column="1"
            Height="200"
            Orientation="Horizontal">
            <TextBlock Margin="5" Text="계좌번호 :" />
            <TextBox
                Width="70"
                Margin="5"
                Text="{Binding UiStrAcountNumber}" />
            <TextBlock Margin="5" Text="APP KEY :" />
            <TextBox
                Width="100"
                Margin="5"
                Text="{Binding UiStrAppKey}" />
            <TextBlock Margin="5" Text="APP SECRET :" />
            <TextBox
                Width="100"
                Margin="5"
                Text="{Binding UiStrAppSecret}" />
            <TextBlock Margin="5" Text="웹접속키 :" />
            <TextBox
                Width="100"
                Margin="5"
                Text="{Binding UiStrWebKey}" />
            <TextBlock Margin="5" Text="토큰 :" />
            <TextBox
                Width="100"
                Margin="5"
                Text="{Binding UiStrToken}" />
        </WrapPanel>

        <WrapPanel
            Grid.Row="2"
            Grid.Column="1"
            Height="100"
            Orientation="Horizontal">
            <Button
                Grid.Column="0"
                Width="100"
                Margin="10"
                Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.BtnGenerateWebKey_Click}"
                CommandParameter="{Binding}"
                Content="웹접속키 생성" />
            <Button
                Grid.Column="1"
                Width="80"
                Margin="10"
                Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.BtnGenerateToken_Click}"
                CommandParameter="{Binding}"
                Content="토큰 생성" />
            <Button
                x:Name="BtnSectionAdd"
                Width="100"
                Height="30"
                Margin="10"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Command="{Binding BtnSectionAdd_Click}"
                Content="계좌추가" />
        </WrapPanel>

        <!--  스크롤 가능한 영역  -->
        <ScrollViewer
            Grid.Row="3"
            Grid.Column="1"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ObcSectionList}">
                <!--<ItemsControl.Style>
                    <Style TargetType="{x:Type ItemsControl}">
                        <Setter Property="BorderThickness" Value="{Binding Thkness}"/>
                    </Style>
                </ItemsControl.Style>-->
                <ItemsControl.Template>
                    <!--  템플릿 외형  -->
                    <ControlTemplate TargetType="{x:Type ItemsControl}">
                        <Border Background="#F6F6F6">
                            <ItemsPresenter />
                        </Border>
                    </ControlTemplate>
                </ItemsControl.Template>

                <ItemsControl.ItemsPanel>
                    <!--  패널 정렬  -->
                    <ItemsPanelTemplate>
                        <StackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>

                            <!--  Grid로 컨텐츠 배치  -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="2*" />
                                </Grid.RowDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Margin="0,20,0,0"
                                    FontSize="20"
                                    FontWeight="Bold"
                                    Text="계좌정보" />

                                <WrapPanel Grid.Row="1" Orientation="Horizontal">
                                    <TextBlock Margin="5" Text="통신 URL :" />
                                    <TextBox
                                        Width="100"
                                        Margin="5"
                                        IsReadOnly="True"
                                        Text="{Binding StrCommunicationUrl}" />
                                    <TextBlock Margin="5" Text="계좌번호 :" />
                                    <TextBox
                                        Width="100"
                                        Margin="5"
                                        IsReadOnly="True"
                                        Text="{Binding StrAccountNumber}" />
                                    <TextBlock Margin="5" Text="APP KEY :" />
                                    <TextBox
                                        Width="100"
                                        Margin="5"
                                        IsReadOnly="True"
                                        Text="{Binding StrAppKey}" />
                                    <TextBlock Margin="5" Text="APP SECRET :" />
                                    <TextBox
                                        Width="100"
                                        Margin="5"
                                        IsReadOnly="True"
                                        Text="{Binding StrAppSecret}" />
                                    <TextBlock Margin="5" Text="웹접속키 :" />
                                    <TextBox
                                        Width="100"
                                        Margin="5"
                                        IsReadOnly="True"
                                        Text="{Binding StrWebKey}" />
                                    <TextBlock Margin="5" Text="토큰 :" />
                                    <TextBox
                                        Width="100"
                                        Margin="5"
                                        IsReadOnly="True"
                                        Text="{Binding StrToken}" />
                                </WrapPanel>


                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button
                                        Grid.Column="0"
                                        Width="150"
                                        Height="30"
                                        Margin="5"
                                        HorizontalAlignment="Left"
                                        Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.BtnDeleteAccount_Click}"
                                        CommandParameter="{Binding}"
                                        Content="계좌삭제" />

                                    <Button
                                        Grid.Column="3"
                                        Width="150"
                                        Height="30"
                                        Margin="5"
                                        HorizontalAlignment="Right"
                                        Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.BtnTradePlanAdd_Click}"
                                        CommandParameter="{Binding}"
                                        Content="방법추가" />
                                </Grid>

                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <ComboBox
                                        Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        ItemsSource="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.ObcStrSearchMethodList}"
                                        SelectedItem="{Binding StrSearchMethod_Add}"
                                        Text="종목검색방법" />

                                    <ComboBox
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        ItemsSource="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.ObcStrBuyMethodList}"
                                        SelectedItem="{Binding StrBuyMethod_Add}"
                                        Text="종목매수방법" />

                                    <ComboBox
                                        Grid.Column="2"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        ItemsSource="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.ObcStrManualMethodList}"
                                        SelectedItem="{Binding StrManualMethod_Add}"
                                        Text="메뉴얼방법" />
                                </Grid>

                                <WrapPanel Grid.Row="4" Orientation="Horizontal">
                                    <ComboBox
                                        Width="200"
                                        Height="30"
                                        VerticalContentAlignment="Center"
                                        ItemsSource="{Binding ObcStockExcdComboBoxItem_Add}"
                                        SelectedItem="{Binding SelectedExchange}" />
                                    <TextBlock Margin="5" Text="종목코드 :" />
                                    <TextBox
                                        Width="100"
                                        Margin="5"
                                        Text="{Binding StrStockSymb_Add}" />
                                    <TextBlock Margin="5" Text="종목명 :" />
                                    <TextBox
                                        Width="100"
                                        Margin="5"
                                        Text="{Binding StrStockName_Add}" />
                                    <Button
                                        Width="100"
                                        Margin="5"
                                        Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.BtnManualStockAdd_Click}"
                                        CommandParameter="{Binding}"
                                        Content="종목수동추가" />
                                </WrapPanel>


                                <!--  ItemsControl를 활용한 플랜리스트  -->
                                <ItemsControl
                                    Grid.Row="5"
                                    Margin="0,15,0,0"
                                    ItemsSource="{Binding ObcStockActionPlanList}">

                                    <!--  템플릿 외형  -->
                                    <ItemsControl.Template>
                                        <ControlTemplate TargetType="{x:Type ItemsControl}">
                                            <StackPanel>
                                                <ItemsPresenter />
                                            </StackPanel>
                                        </ControlTemplate>
                                    </ItemsControl.Template>

                                    <!--  데이터 외형  -->
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <ComboBox
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    ItemsSource="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.ObcStrSearchMethodList}"
                                                    SelectedItem="{Binding StrSearchMethod, Mode=TwoWay}"
                                                    Text="종목검색방법" />

                                                <ComboBox
                                                    Grid.Row="0"
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    ItemsSource="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.ObcStrBuyMethodList}"
                                                    SelectedItem="{Binding StrBuyMethod, Mode=TwoWay}"
                                                    Text="종목매수방법" />

                                                <ComboBox
                                                    Grid.Row="0"
                                                    Grid.Column="2"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    ItemsSource="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.ObcStrManualMethodList}"
                                                    SelectedItem="{Binding StrManualMethod, Mode=TwoWay}"
                                                    Text="메뉴얼방법" />

                                                <Button
                                                    x:Name="BtnStart"
                                                    Grid.Row="0"
                                                    Grid.Column="3"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.BtnTradePlanStart_Click}"
                                                    CommandParameter="{Binding}"
                                                    Content="실행"
                                                    IsEnabled="{Binding BlIsActive, Converter={StaticResource IsEnabledStartConverter}}" />
                                                <Button
                                                    x:Name="BtnStop"
                                                    Grid.Row="0"
                                                    Grid.Column="4"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.BtnTradePlanStop_Click}"
                                                    CommandParameter="{Binding}"
                                                    Content="정지"
                                                    IsEnabled="{Binding BlIsActive, Converter={StaticResource IsEnabledStopConverter}}" />
                                                <Button
                                                    x:Name="BtnDelete"
                                                    Grid.Row="0"
                                                    Grid.Column="5"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.BtnTradePlanDelete_Click}"
                                                    CommandParameter="{Binding}"
                                                    Content="삭제"
                                                    IsEnabled="{Binding BlIsActive, Converter={StaticResource IsEnabledStartConverter}}" />

                                                <Grid
                                                    Grid.Row="1"
                                                    Grid.ColumnSpan="6"
                                                    Margin="5,10,5,10">

                                                    <ScrollViewer
                                                        Height="300"
                                                        CanContentScroll="False"
                                                        PreviewMouseWheel="InnerScrollViewer_PreviewMouseWheel"
                                                        VerticalScrollBarVisibility="Auto">
                                                        <ItemsControl ItemsSource="{Binding ObFilteredStockList}">
                                                            <ItemsControl.Template>
                                                                <!--  템플릿 외형  -->
                                                                <ControlTemplate TargetType="{x:Type ItemsControl}">
                                                                    <ItemsPresenter />
                                                                </ControlTemplate>
                                                            </ItemsControl.Template>

                                                            <ItemsControl.ItemsPanel>
                                                                <!--  패널 정렬  -->
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>

                                                            <!--  템플릿 내형  -->
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border
                                                                        Padding="5"
                                                                        BorderBrush="LightGray"
                                                                        BorderThickness="0,0,0,1">

                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="1*" />
                                                                                <ColumnDefinition Width="1*" />
                                                                                <ColumnDefinition Width="2*" />
                                                                                <ColumnDefinition Width="3*" />
                                                                                <ColumnDefinition Width="1*" />
                                                                            </Grid.ColumnDefinitions>

                                                                            <Grid.RowDefinitions>
                                                                                <RowDefinition Height="*" />
                                                                                <RowDefinition Height="Auto" />
                                                                                <RowDefinition Height="*" />
                                                                                <RowDefinition Height="Auto" />
                                                                                <RowDefinition Height="*" />
                                                                            </Grid.RowDefinitions>

                                                                            <Border
                                                                                Grid.Row="0"
                                                                                Grid.Column="0"
                                                                                BorderBrush="LightGray"
                                                                                BorderThickness="0,0,2,0">
                                                                                <TextBox
                                                                                    Width="60"
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    HorizontalContentAlignment="Center"
                                                                                    IsReadOnly="True"
                                                                                    Text="{Binding StrStockSymb}" />
                                                                            </Border>

                                                                            <Border
                                                                                Grid.Row="0"
                                                                                Grid.Column="1"
                                                                                BorderBrush="LightGray"
                                                                                BorderThickness="0,0,2,0">
                                                                                <TextBlock
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Text="{Binding StrStockName}" />
                                                                            </Border>

                                                                            <Border
                                                                                Grid.Row="0"
                                                                                Grid.Column="2"
                                                                                BorderBrush="LightGray"
                                                                                BorderThickness="0,0,2,0">
                                                                                <TextBlock
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Text="{Binding DtRsiCheckedAt, StringFormat='{}{0:HH:mm:ss}'}" />
                                                                            </Border>

                                                                            <Border
                                                                                Grid.Row="0"
                                                                                Grid.Column="3"
                                                                                BorderBrush="LightGray"
                                                                                BorderThickness="0,0,2,0">
                                                                                <TextBlock
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Text="{Binding StrRsiValue}" />
                                                                            </Border>

                                                                            <Border
                                                                                Grid.Row="0"
                                                                                Grid.Column="4"
                                                                                BorderBrush="LightGray"
                                                                                BorderThickness="0,0,2,0">
                                                                                <TextBlock
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Text="{Binding StrSimulatedRsi}" />
                                                                            </Border>

                                                                            <Border
                                                                                Grid.Row="0"
                                                                                Grid.Column="5"
                                                                                BorderBrush="LightGray"
                                                                                BorderThickness="0,0,2,0">
                                                                                <Button
                                                                                    Width="80"
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Command="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Window}, AncestorLevel=1}, Path=DataContext.BtnStockDelete_Click}"
                                                                                    CommandParameter="{Binding}"
                                                                                    Content="삭제" />
                                                                            </Border>

                                                                            <GridSplitter
                                                                                Grid.Row="1"
                                                                                Height="10"
                                                                                Background="Transparent" />

                                                                            <Border
                                                                                Grid.Row="2"
                                                                                Grid.Column="3"
                                                                                BorderBrush="LightGray"
                                                                                BorderThickness="0,0,2,0">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*" />
                                                                                        <ColumnDefinition Width="*" />
                                                                                    </Grid.ColumnDefinitions>


                                                                                    <TextBlock
                                                                                        Grid.Column="0"
                                                                                        HorizontalAlignment="Stretch"
                                                                                        VerticalAlignment="Stretch">
                                                                                        <TextBlock.Background>
                                                                                            <MultiBinding Converter="{StaticResource MultiFibonacciColorConverter}">
                                                                                                <Binding Path="StrStockSymb" />
                                                                                                <Binding Path="DmDayLast" />
                                                                                                <Binding Path="DmFibonacci_Red" />
                                                                                                <Binding Path="DmFibonacci_Orange" />
                                                                                                <Binding Path="DmFibonacci_Green" />
                                                                                                <Binding Path="DmFibonacci_Blue" />
                                                                                                <Binding Path="DmFibonacci_Purple" />
                                                                                            </MultiBinding>
                                                                                        </TextBlock.Background>
                                                                                    </TextBlock>

                                                                                    <TextBlock
                                                                                        Grid.Column="1"
                                                                                        HorizontalAlignment="Stretch"
                                                                                        VerticalAlignment="Stretch">
                                                                                        <TextBlock.Background>
                                                                                            <MultiBinding Converter="{StaticResource MultiFibonacciColorConverter}">
                                                                                                <Binding Path="StrStockSymb" />
                                                                                                <Binding Path="DmDayLast" />
                                                                                                <Binding Path="DmFibonacci_Red" />
                                                                                                <Binding Path="DmFibonacci_Orange" />
                                                                                                <Binding Path="DmFibonacci_Green" />
                                                                                                <Binding Path="DmFibonacci_Blue" />
                                                                                                <Binding Path="DmFibonacci_Purple" />
                                                                                            </MultiBinding>
                                                                                        </TextBlock.Background>
                                                                                    </TextBlock>
                                                                                </Grid>
                                                                            </Border>

                                                                            <Border
                                                                                Grid.Row="2"
                                                                                Grid.Column="4"
                                                                                BorderBrush="LightGray"
                                                                                BorderThickness="0,0,2,0">
                                                                                <TextBlock
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Text="{Binding StrFibonacciComparison}" />
                                                                            </Border>

                                                                            <GridSplitter
                                                                                Grid.Row="3"
                                                                                Height="10"
                                                                                Background="Transparent" />

                                                                            <Border
                                                                                Grid.Row="4"
                                                                                Grid.Column="3"
                                                                                BorderBrush="LightGray"
                                                                                BorderThickness="0,0,2,0">
                                                                                <TextBlock
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Text="{Binding StrHighDropPercentRange}" />
                                                                            </Border>

                                                                            <Border
                                                                                Grid.Row="4"
                                                                                Grid.Column="4"
                                                                                BorderBrush="LightGray"
                                                                                BorderThickness="0,0,2,0">
                                                                                <TextBlock
                                                                                    HorizontalAlignment="Center"
                                                                                    VerticalAlignment="Center"
                                                                                    Text="{Binding StrHighDropPercentTargetInfo}" />
                                                                            </Border>

                                                                        </Grid>

                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>

                                                </Grid>

                                                <Grid
                                                    Grid.Row="2"
                                                    Grid.ColumnSpan="6"
                                                    Margin="0,0,0,15">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock
                                                        VerticalAlignment="Top"
                                                        FontSize="15"
                                                        FontWeight="Bold"
                                                        Text="Message" />

                                                    <TextBox
                                                        Grid.Column="1"
                                                        Margin="5,0,0,0"
                                                        AcceptsReturn="True"
                                                        FontSize="15"
                                                        Text="{Binding StrMessage}"
                                                        TextWrapping="Wrap"
                                                        VerticalScrollBarVisibility="Auto" />
                                                </Grid>

                                            </Grid>

                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>

                                    <!--  패널 정렬  -->
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                </ItemsControl>

                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
